[gd_resource type="Resource" script_class="EncounterData" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/resources/encounter_data.gd" id="1_enc"]
[ext_resource type="Script" path="res://scripts/resources/encounter_option_data.gd" id="2_opt"]

[sub_resource type="Resource" id="Resource_opt1"]
script = ExtResource("2_opt")
label = "Rozbij zamek (zużyj 1 materiał)"
result_text = "W skrzyni znajdujesz notatki starego trapera — wybierz nową kartę."
materials_delta = -1
grants_card_choice = true

[sub_resource type="Resource" id="Resource_opt2"]
script = ExtResource("2_opt")
label = "Zostaw skrzynię"
result_text = "Może wróci po nią właściciel. Ruszasz dalej."

[resource]
script = ExtResource("1_enc")
id = "trapper_cache"
title = "Schowek trapera"
text = "Pod wykrotem ktoś ukrył okutą skrzynię. Zamek jest zardzewiały, ale trzyma."
options = [SubResource("Resource_opt1"), SubResource("Resource_opt2")]
