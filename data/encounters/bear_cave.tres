[gd_resource type="Resource" script_class="EncounterData" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/resources/encounter_data.gd" id="1_enc"]
[ext_resource type="Script" path="res://scripts/resources/encounter_option_data.gd" id="2_opt"]

[sub_resource type="Resource" id="Resource_opt1"]
script = ExtResource("2_opt")
label = "Zakradnij się po zapasy"
result_text = "Wygarniasz ile się da, ale niedźwiedź budzi się i sięga cię pazurem. +3 jedzenia, -2 zdrowia."
health_delta = -2
food_delta = 3

[sub_resource type="Resource" id="Resource_opt2"]
script = ExtResource("2_opt")
label = "Zbierz zioła przy wejściu"
result_text = "Przy jaskini rosną rzadkie zioła. Robisz z nich okład. +1 zdrowia."
health_delta = 1

[sub_resource type="Resource" id="Resource_opt3"]
script = ExtResource("2_opt")
label = "Omiń szerokim łukiem"
result_text = "Niedźwiedź śpi dalej. Ty żyjesz dalej. Uczciwy układ."

[resource]
script = ExtResource("1_enc")
id = "bear_cave"
title = "Jaskinia niedźwiedzia"
text = "Z ciemnej jaskini dobiega chrapliwy oddech. W środku majaczą zapasy upolowanej zwierzyny."
options = [SubResource("Resource_opt1"), SubResource("Resource_opt2"), SubResource("Resource_opt3")]
