[resource]
script = ExtResource("1_script")
id = "rift"
display_name = "Pęknięcie"
description = "Ziemia pęka z hukiem. Z rozpadlin bucha pył i wypełzają istoty z głębi."
monsters = [ExtResource("2_golem"), ExtResource("3_swarm"), ExtResource("4_crawler")]
extra_event_cards = [ExtResource("5_after"), ExtResource("6_dust"), ExtResource("7_chasm")]
act2_thirst_decay_delta = 1
act2_energy_penalty = 2
act2_rule_text = "Pęknięcie: wstrząsy i pył — sprzątanie rumowiska wyczerpuje (-2 energii, większe pragnienie)."
