[gd_resource type="Resource" script_class="BiomeData" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/resources/biome_data.gd" id="1_script"]
[ext_resource type="Resource" path="res://data/cards/actions/scavenge.tres" id="2_scav"]
[ext_resource type="Resource" path="res://data/cards/actions/find_water.tres" id="3_water"]
[ext_resource type="Resource" path="res://data/cards/events/biome/caves_rockfall.tres" id="4_rockfall"]
[ext_resource type="Resource" path="res://data/cards/events/biome/caves_dark.tres" id="5_dark"]
[ext_resource type="Resource" path="res://data/cards/actions/corrupted/murky_water.tres" id="6_murky"]
[ext_resource type="Resource" path="res://data/cards/events/sickness.tres" id="7_sick"]

[resource]
script = ExtResource("1_script")
id = "caves"
display_name = "Jaskinie"
description = "Mroczne korytarze z rudą i podziemnym źródłem. Strop bywa zdradliwy."
building_slots = 2
gather_cards = [ExtResource("2_scav"), ExtResource("3_water")]
extra_event_cards = [ExtResource("4_rockfall"), ExtResource("5_dark")]
corrupted_display_name = "Zatrute Jaskinie"
corrupted_description = "Ze szczelin sączy się czarna maź, a echo niesie nieludzkie skrzeki."
corrupted_gather_cards = [ExtResource("2_scav"), ExtResource("6_murky")]
corrupted_extra_event_cards = [ExtResource("7_sick")]
