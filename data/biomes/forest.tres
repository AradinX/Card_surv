[gd_resource type="Resource" script_class="BiomeData" load_steps=9 format=3]

[ext_resource type="Script" path="res://scripts/resources/biome_data.gd" id="1_script"]
[ext_resource type="Resource" path="res://data/cards/actions/gather_wood.tres" id="2_wood"]
[ext_resource type="Resource" path="res://data/cards/actions/forage.tres" id="3_forage"]
[ext_resource type="Resource" path="res://data/cards/actions/hunt.tres" id="4_hunt"]
[ext_resource type="Resource" path="res://data/cards/events/wolves.tres" id="5_wolves"]
