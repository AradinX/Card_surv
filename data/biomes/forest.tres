[resource]
script = ExtResource("1_script")
id = "forest"
display_name = "Las"
description = "Gęsty las pełen drewna i zwierzyny. Nocą słychać wilki."
building_slots = 3
gather_cards = [ExtResource("2_wood"), ExtResource("3_forage"), ExtResource("4_hunt"), ExtResource("8_water")]
extra_event_cards = [ExtResource("5_wolves")]
corrupted_display_name = "Martwy Las"
corrupted_description = "Drzewa stoją czarne i nagie. Coś porusza się między pniami."
corrupted_gather_cards = [ExtResource("6_scav")]
corrupted_extra_event_cards = [ExtResource("7_sick")]
