[resource]
script = ExtResource("1_script")
id = "forest"
display_name = "Las"
description = "Gęsty las pełen drewna i zwierzyny. Nocą słychać wilki."
building_slots = 2
gather_cards = [ExtResource("2_wood"), ExtResource("4_hunt")]
extra_event_cards = [ExtResource("5_wolves"), ExtResource("11_boar"), ExtResource("12_lost"), ExtResource("13_smallfind"), ExtResource("14_strangeberries"), ExtResource("17_birdsong"), ExtResource("18_mist"), ExtResource("19_deer"), ExtResource("20_resin")]
corrupted_display_name = "Martwy Las"
corrupted_description = "Drzewa stoją czarne i nagie. Coś porusza się między pniami."
corrupted_gather_cards = [ExtResource("2_wood"), ExtResource("6_scav"), ExtResource("9_tainted"), ExtResource("10_murky"), ExtResource("15_rotten")]
corrupted_extra_event_cards = [ExtResource("7_sick"), ExtResource("16_whispers"), ExtResource("21_roots"), ExtResource("22_mold")]
