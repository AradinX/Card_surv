[resource]
script = ExtResource("1_script")
id = "meadows"
display_name = "Łąki"
description = "Otwarta, żyzna przestrzeń. Najlepsze miejsce pod osadę."
building_slots = 2
gather_cards = [ExtResource("2_forage"), ExtResource("3_snare")]
extra_event_cards = [ExtResource("4_sunny"), ExtResource("8_pollen"), ExtResource("9_chill"), ExtResource("10_berry"), ExtResource("13_breeze"), ExtResource("14_fireflies"), ExtResource("15_larks"), ExtResource("16_dew")]
