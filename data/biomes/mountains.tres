[resource]
script = ExtResource("1_script")
id = "mountains"
display_name = "Góry"
description = "Surowe skały bogate w kamień. Zima przychodzi tu pierwsza."
building_slots = 2
camp_warmth_loss = 1
gather_cards = [ExtResource("2_scav"), ExtResource("7_water")]
extra_event_cards = [ExtResource("4_cold"), ExtResource("5_storm"), ExtResource("9_thin"), ExtResource("11_echo"), ExtResource("12_eagle"), ExtResource("13_clearair"), ExtResource("14_snowdust")]
corrupted_display_name = "Wyjące Góry"
corrupted_description = "Wiatr w szczelinach brzmi jak głosy. Nie schodź w doliny."
corrupted_gather_cards = [ExtResource("3_sticks"), ExtResource("8_murky")]
corrupted_extra_event_cards = [ExtResource("6_fog"), ExtResource("10_howl"), ExtResource("15_quake"), ExtResource("16_frost")]
