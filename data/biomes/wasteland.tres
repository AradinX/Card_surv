[gd_resource type="Resource" script_class="BiomeData" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/resources/biome_data.gd" id="1_script"]
[ext_resource type="Resource" path="res://data/cards/actions/scavenge.tres" id="2_scav"]
[ext_resource type="Resource" path="res://data/cards/actions/forage.tres" id="3_forage"]
[ext_resource type="Resource" path="res://data/cards/events/biome/wasteland_dust_storm.tres" id="4_dust"]
[ext_resource type="Resource" path="res://data/cards/events/biome/wasteland_scarcity.tres" id="5_scarcity"]
[ext_resource type="Resource" path="res://data/cards/actions/corrupted/murky_water.tres" id="6_murky"]
[ext_resource type="Resource" path="res://data/cards/events/sickness.tres" id="7_sick"]

[resource]
script = ExtResource("1_script")
id = "wasteland"
display_name = "Pustkowie"
description = "Spalona, jałowa ziemia usiana gruzem. Kamienia w bród, jedzenia jak na lekarstwo."
building_slots = 3
gather_cards = [ExtResource("2_scav"), ExtResource("3_forage")]
extra_event_cards = [ExtResource("4_dust"), ExtResource("5_scarcity")]
corrupted_display_name = "Spopielone Pustkowie"
corrupted_description = "Ziemia spieczona na popiół, a w powietrzu wisi gryzący, trujący pył."
corrupted_gather_cards = [ExtResource("2_scav"), ExtResource("6_murky")]
corrupted_extra_event_cards = [ExtResource("7_sick")]
