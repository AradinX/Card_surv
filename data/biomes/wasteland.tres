[resource]
script = ExtResource("1_script")
id = "wasteland"
display_name = "Pustkowie"
description = "Spalona, jałowa ziemia usiana gruzem. Kamienia w bród, jedzenia jak na lekarstwo."
building_slots = 3
gather_cards = [ExtResource("2_scav"), ExtResource("3_forage")]
extra_event_cards = [ExtResource("4_dust"), ExtResource("5_scarcity"), ExtResource("8_lucky"), ExtResource("9_cache")]
corrupted_display_name = "Spopielone Pustkowie"
corrupted_description = "Ziemia spieczona na popiół, a w powietrzu wisi gryzący, trujący pył."
corrupted_gather_cards = [ExtResource("2_scav"), ExtResource("6_murky"), ExtResource("10_salvage")]
corrupted_extra_event_cards = [ExtResource("7_sick")]
