[resource]
script = ExtResource("1_script")
id = "swamp"
display_name = "Bagno"
description = "Grząskie mokradła pełne wody i ziół, ale wilgoć niesie choroby."
building_slots = 2
camp_sickness_chance = 0.3
camp_sickness_damage = 2
gather_cards = [ExtResource("2_water"), ExtResource("3_forage")]
extra_event_cards = [ExtResource("4_fever"), ExtResource("5_miasma"), ExtResource("11_frogs"), ExtResource("12_damp"), ExtResource("13_herbs"), ExtResource("14_wisps")]
corrupted_display_name = "Trujące Mokradła"
corrupted_description = "Woda zaszła zgnilizną, a spod mułu sączy się czarna maź."
corrupted_gather_cards = [ExtResource("6_scav"), ExtResource("7_murky"), ExtResource("8_tainted")]
