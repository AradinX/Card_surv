[gd_resource type="Resource" script_class="BiomeData" load_steps=10 format=3]

[ext_resource type="Script" path="res://scripts/resources/biome_data.gd" id="1_script"]
[ext_resource type="Resource" path="res://data/cards/actions/find_water.tres" id="2_water"]
[ext_resource type="Resource" path="res://data/cards/actions/forage.tres" id="3_forage"]
[ext_resource type="Resource" path="res://data/cards/events/biome/swamp_fever.tres" id="4_fever"]
[ext_resource type="Resource" path="res://data/cards/events/biome/swamp_miasma.tres" id="5_miasma"]
[ext_resource type="Resource" path="res://data/cards/actions/scavenge.tres" id="6_scav"]
[ext_resource type="Resource" path="res://data/cards/actions/corrupted/murky_water.tres" id="7_murky"]
[ext_resource type="Resource" path="res://data/cards/actions/corrupted/tainted_hunt.tres" id="8_tainted"]
[ext_resource type="Resource" path="res://data/cards/events/sickness.tres" id="9_sick"]

[resource]
script = ExtResource("1_script")
id = "swamp"
display_name = "Bagno"
description = "Grząskie mokradła pełne wody i ziół, ale wilgoć niesie choroby."
building_slots = 2
gather_cards = [ExtResource("2_water"), ExtResource("3_forage")]
extra_event_cards = [ExtResource("4_fever"), ExtResource("5_miasma")]
corrupted_display_name = "Trujące Mokradła"
corrupted_description = "Woda zaszła zgnilizną, a spod mułu sączy się czarna maź."
corrupted_gather_cards = [ExtResource("6_scav"), ExtResource("7_murky"), ExtResource("8_tainted")]
corrupted_extra_event_cards = [ExtResource("9_sick")]
