[resource]
script = ExtResource("1_script")
id = "coast"
display_name = "Wybrzeże"
description = "Skalisty brzeg morza: ryby w wodzie i złom z rozbitych łodzi. Sztormy bywają groźne."
building_slots = 3
gather_cards = [ExtResource("2_fishing"), ExtResource("3_scav")]
extra_event_cards = [ExtResource("4_storm"), ExtResource("5_tide"), ExtResource("10_waves"), ExtResource("11_gulls"), ExtResource("12_driftwood"), ExtResource("13_tidepool")]
corrupted_display_name = "Martwe Wybrzeże"
corrupted_description = "Morze wyrzuca na brzeg zgniłe ryby, a fale niosą tłustą, czarną pianę."
corrupted_gather_cards = [ExtResource("3_scav"), ExtResource("6_tainted"), ExtResource("8_salvage")]
corrupted_extra_event_cards = [ExtResource("7_sick"), ExtResource("9_foam"), ExtResource("14_redtide"), ExtResource("15_saltwind")]
