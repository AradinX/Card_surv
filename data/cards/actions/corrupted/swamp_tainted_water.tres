id = "swamp_tainted_water"
display_name = "Czarna kałuża"
description = "Zbierasz to, co zostało z kałuży zgnilizny — brzydko wygląda, gorzej pachnie."
plague_description = "Gęsta, czarno-zielona woda bagienna błyszczy tłustym połyskiem."
eclipse_description = "Powierzchnię bagna skuł lód — pod pękniętą taflą wciąż jest woda."
flood_description = "Deszcz podniósł poziom bagna, zalewając omszały pień."
rift_description = "Bagno wyschło do spękanego błota, na resztkach wody osiada kurz."
