id = "swamp_tainted"
display_name = "Podejrzana zdobycz"
description = "Wyciągasz coś z mułu. Wygląda podejrzanie, ale mówisz sobie, że jeszcze jadalne."
plague_description = "Wyciągasz z mułu coś wzdętego, pokrytego fioletowym nalotem grzyba."
eclipse_description = "To, co złapałeś, jest wmarznięte w taflę bagna — trzeba wyrąbać."
flood_description = "Zdobycz unosi się na powierzchni zalanego bagna, napęczniała od deszczu."
rift_description = "Znajdujesz ją zeschniętą w spękanym błocie tam, gdzie bagno wyschło."
