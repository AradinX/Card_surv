[gd_resource type="Resource" script_class="EventCardData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_card_data.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/resources/event_choice_data.gd" id="2_choice"]

[sub_resource type="Resource" id="leave"]
script = ExtResource("2_choice")
label = "Zostaw to"
result_text = "Lepiej głód niż zaraza. Odchodzisz."

[sub_resource type="Resource" id="eat"]
script = ExtResource("2_choice")
label = "Usmaż mimo to (ryzyko)"
result_text = "Ogień powinien zabić to, co w środku. Powinien."
hunger_delta = 5
food_gain = 1
risk_chance = 45
risk_health = 7

[resource]
script = ExtResource("1_script")
id = "plague_dilemma_tainted_meat"
display_name = "Skażone mięso"
description = "Tłusta padlina kusi zapachem, choć skóra pod sierścią pulsuje czymś żywym."
weight = 6
cooldown_days = 4
max_per_run = 2
category = "disaster"
severity = "medium"
choices = [SubResource("leave"), SubResource("eat")]
