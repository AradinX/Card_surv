[gd_resource type="Resource" script_class="EventCardData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/resources/event_card_data.gd" id="1_script"]
[ext_resource type="Script" path="res://scripts/resources/event_choice_data.gd" id="2_choice"]

[sub_resource type="Resource" id="safe"]
script = ExtResource("2_choice")
label = "Zostaw zmarłego"
result_text = "Niech spoczywa. Odwracasz wzrok."

[sub_resource type="Resource" id="risk"]
script = ExtResource("2_choice")
label = "Zabierz plecak (ryzyko)"
result_text = "Brodzisz po pas w gnijącej wodzie, by ściągnąć tobół z ciała."
materials_gain = 2
water_gain = 1
risk_chance = 35
risk_health = 2

[resource]
script = ExtResource("1_script")
id = "flood_dilemma_drowned_pack"
display_name = "Plecak topielca"
description = "Obok obozu przepływa wzdęte ciało z pełnym, dobrze zapakowanym plecakiem."
weight = 6
cooldown_days = 4
max_per_run = 2
category = "disaster"
severity = "medium"
choices = [SubResource("safe"), SubResource("risk")]
