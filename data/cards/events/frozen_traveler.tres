[sub_resource type="Resource" id="pass"]
script = ExtResource("2_choice")
label = "Minij obojętnie"
result_text = "Zostawiasz go własnemu losowi."

[resource]
script = ExtResource("1_script")
id = "frozen_traveler"
display_name = "Zmarznięty podróżny"
