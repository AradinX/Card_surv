[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_panel"]

[sub_resource type="Shader" id="Shader_chroma"]
code = "shader_type canvas_item;
uniform vec3 outside_key = vec3(1.0, 0.0, 1.0);
uniform vec3 art_key = vec3(0.0, 0.31, 1.0);
uniform float tolerance = 0.18;
void fragment() {
	vec4 col = texture(TEXTURE, UV);
	float outside_dist = distance(col.rgb, outside_key);
	float art_dist = distance(col.rgb, art_key);
	if (col.a < 0.01 || outside_dist < tolerance || art_dist < tolerance) {
		col.a = 0.0;
	} else {
		col.a = 1.0;
	}
	COLOR = col;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_panel"]
shader = SubResource("Shader_chroma")
shader_parameter/outside_key = Vector3(1, 0, 1)
shader_parameter/art_key = Vector3(0, 0.31, 1)
shader_parameter/tolerance = 0.18

